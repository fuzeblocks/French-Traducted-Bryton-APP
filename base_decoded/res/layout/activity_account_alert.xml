<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <RelativeLayout android:id="@id/login_3rd_party_alert_layout" android:background="@color/bg_dark_primary" android:visibility="visible" android:layout_width="match_parent" android:layout_height="match_parent">
        <TextView android:textSize="15.0sp" android:textStyle="normal" android:textColor="#ffffff" android:id="@id/alert_1_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20.0dp" android:text="As of 21st Sept. 2020, we decided to remove the Facebook and Strava 3rd Party login options from Bryton Active. After careful consideration, this decision was made in order to avoid login confusion and prevent ride data loss from forgotten passwords.             \n\nIf you used the login with Facebook or Strava options for your Bryton account, please visit:" android:layout_centerHorizontal="true" android:lineSpacingExtra="3.0sp" android:fontFamily="sans-serif" android:layout_marginStart="25.0dp" android:layout_marginEnd="25.0dp" />
        <TextView android:textSize="15.0sp" android:textStyle="normal" android:textColor="@color/main_green" android:id="@id/login_url_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20.0dp" android:text="http://login.brytonsport.com" android:layout_below="@id/alert_1_text" android:lineSpacingExtra="3.0sp" android:fontFamily="sans-serif-medium" android:layout_marginStart="25.0dp" />
        <TextView android:textSize="15.0sp" android:textStyle="normal" android:textColor="#ffffff" android:id="@id/alert_2_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20.0dp" android:text="To add an email login for your account. After the email has been added, you can log in to Bryton Active using these credentials with a more stable and faster experience.             \n\nDon’t worry, the Bryton devices and data from your account will NOT be lost.             \n\nWe sincerely apologize for the inconveniences caused." android:layout_below="@id/login_url_text" android:layout_centerHorizontal="true" android:lineSpacingExtra="3.0sp" android:fontFamily="sans-serif" android:layout_marginStart="25.0dp" android:layout_marginEnd="25.0dp" />
    </RelativeLayout>
</RelativeLayout>
